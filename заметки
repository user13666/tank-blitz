// Очередь для обработки перемещений игроков
// concurrency: 1 гарантирует строгую последовательность
const clanFlowQueue = async.queue(async (task, callback) => {
  const { userId, clanId, action } = task;

  if (action === 'leave') {
    await handleLeaveClan(userId, clanId);
  } else if (action === 'join') {
    await handleJoinClan(userId, clanId);
  }

  callback(); // Успех
}, 1);

async function handleLeaveClan(userId, clanId) {
  // Используем транзакцию: либо всё обновится, либо ничего
  await usersDb.transaction('rw', [usersDb.users, usersDb.clanHistory], async () => {
    const existing = await usersDb.clanHistory.where('[userId+clanId]').equals([userId, clanId]).first();
    if (existing) {
      // Если запись была, обновляем дату последнего выхода
      await usersDb.clanHistory.update(existing.id, { exitDate: Date.now() });
    } else {
      // Если нет — создаем новую
      await usersDb.clanHistory.add({ userId, clanId, exitDate: Date.now() });
    }
  });
}

async function handleJoinClan(userId, clanId) {
  // Используем транзакцию: либо всё обновится, либо ничего
  await usersDb.transaction('rw', [usersDb.users, usersDb.clanHistory], async () => {
    const existing = await usersDb.clanHistory.where('[userId+clanId]').equals([userId, clanId]).first();
    if (existing) {
      // Если запись была, обновляем дату последнего выхода
      await usersDb.clanHistory.update(existing.id, { exitDate: Date.now() });
    } else {
      // Если нет — создаем новую
      await usersDb.clanHistory.add({ userId, clanId, exitDate: Date.now() });
    }
  });
}

