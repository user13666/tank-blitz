async function savePointsUsers(usersDb, usersIdArr) {
  const savePointsBlock = document.getElementById('savePoints');
  savePointsBlock.onclick = async () => {
    const userPoints = document.querySelectorAll('.user-input');
    const userDate = document.getElementById('userDate');
    const userDateValue = userDate.value;
    if (!userDateValue) return;
    if (!checkNumInputs(userPoints)) return;
    if (usersIdArr?.length === 0) return;
    await usersDb.transaction('rw', usersDb.users, async () => {
      // Получаем текущие данные для этих ID
      const users = await usersDb.users.bulkGet(usersIdArr);
      // Формируем массив обновлений
      const filterUsers = users.filter(user => user !== undefined); // Пропускаем, если ID не найден
      if (filterUsers?.length === 0) return;
      const usersData = filterUsers.map(user => {
        const inputBlock = document.getElementById(`points-${user.id}`)?.value ?? '0';

        return {
          key: user.id,
          changes: {
            points: [...user.points, { [userDateValue]: +inputBlock }],
          },
        };
      });
      await usersDb.users.bulkUpdate(usersData);
    });
  };
}


async function processLargeObjArr(obj, startFunction, endFunction, maxTimePerChunk = 16, type = '') {
  let startTime = nowTime();
  if (type === 'async') {
    for (const key in obj) {
      if (!Object.hasOwn(obj, key)) continue;
      if (nowTime() - startTime >= maxTimePerChunk) {
        await PauseBetweenOperations(0, 4);
        startTime = nowTime();
      }
      await startFunction(obj[key], key);
    }
    if (endFunction) await endFunction();
  } else {
    for (const key in obj) {
      if (!Object.hasOwn(obj, key)) continue;
      if (nowTime() - startTime >= maxTimePerChunk) {
        await PauseBetweenOperations(0, 4);
        startTime = nowTime();
      }
      startFunction(obj[key], key);
    }
    if (endFunction) endFunction();
  }
}

async function processLargeArray(array, startFunction, endFunction, maxTimePerChunk = 16, type = '') {
  let startTime = nowTime();
  const len = array.length;

  if (type === 'async') {
    for (let i = 0; i < len; i += 1) {
      // Проверка: пора ли сделать перерыв?
      if (nowTime() - startTime >= maxTimePerChunk) {
        await PauseBetweenOperations(0, 4);
        startTime = nowTime(); // Сброс таймера после паузы
      }
      // Передаем в функцию: элемент, индекс и сам массив
      await startFunction(array[i], i, array);
    }
    if (endFunction) await endFunction();
  } else {
    for (let i = 0; i < len; i += 1) {
      if (nowTime() - startTime >= maxTimePerChunk) {
        await PauseBetweenOperations(0, 4);
        startTime = nowTime();
      }
      startFunction(array[i], i, array);
    }
    if (endFunction) endFunction();
  }
}

